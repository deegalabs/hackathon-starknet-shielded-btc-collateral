# =============================================================================
# Shielded BTC Collateral Protocol — Frontend Environment
# =============================================================================
#
# OPTION A: Local devnet (development)
#   starknet-devnet --seed 0 --port 5050
#   cd scripts && pnpm demo  (deploys all contracts, prints addresses)
#
# OPTION B: Sepolia testnet (live demo)
#   ./scripts/deploy_sepolia.sh  (requires funded account)
#   cp deployment/frontend.env.sepolia .env
#
# =============================================================================

# Network configuration
VITE_NETWORK=devnet
VITE_RPC_URL=http://127.0.0.1:5050

# For Sepolia:
# VITE_NETWORK=sepolia
# VITE_RPC_URL=https://starknet-sepolia.public.blastapi.io

# Contract addresses
# Local devnet: run `pnpm demo` in /scripts to deploy and get these addresses
# Sepolia: run `./scripts/deploy_sepolia.sh` to deploy
VITE_WBTC_ADDRESS=
VITE_VAULT_ADDRESS=
VITE_LENDING_ADDRESS=
VITE_PAYMASTER_ADDRESS=
VITE_SESSION_KEY_MANAGER_ADDRESS=

# ShieldedAccount class hash
# Run `scarb build && sncast declare --contract-name ShieldedAccount` to get this.
# Required to enable the "Create Protocol Account" (/account page) feature.
VITE_SHIELDED_ACCOUNT_CLASS_HASH=

# Explorer base URL (optional — used for transaction links)
VITE_VOYAGER_URL=https://sepolia.voyager.online
