# Network: devnet | sepolia | mainnet
VITE_NETWORK=devnet
VITE_RPC_URL=http://127.0.0.1:5050

# Contract addresses — run `pnpm demo` in /scripts to deploy and get these
VITE_WBTC_ADDRESS=
VITE_VAULT_ADDRESS=
VITE_LENDING_ADDRESS=
VITE_PAYMASTER_ADDRESS=
VITE_SESSION_KEY_MANAGER_ADDRESS=

# ShieldedAccount class hash — run `sncast declare --contract-name ShieldedAccount` to get this
# Required to enable the "Create Protocol Account" feature
VITE_SHIELDED_ACCOUNT_CLASS_HASH=
